{
    "manifest_version": 3,
    "name": "Turnstile Patch",
    "version": "1.0.0",
    "description": "Patch browser automation detection for Turnstile",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true,
            "world": "MAIN"
        }
    ],
    "permissions": ["activeTab"],
    "host_permissions": ["<all_urls>"]
}
